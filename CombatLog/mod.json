{
  "Name": "CombatLog",
  "Enabled": true,
  "Version": "2.0.0",
  "Description": "Displays a combat log and stats overlay during BattleTech missions and an Argo log when back aboard the Argo",
  "Author": "Vas7eel",
  "Website": "",
  "Contact": "",
  "DLL": "CombatLog.dll",
  "DLLEntryPoint": "CombatLog.Main.Init",

  "Settings": {
    "DebugLog": false,
    "DebugWindow": false,

    "AutoClearOnMission": true,
    "StartVisible": true,
    "EndVisible": false,
    "SeparateArgoLayouts": true,
    "AutohideArgoLog": true,
    "FogOfWarNames": true,
    "ShowToHitChance": true,
    "ShowEnemyToHitChance": false,
    "ShowInitiative": true,
    "ShowCrits": true,
    "ShowKnockdowns": true,
    "ShowMisses": true,
    "ShowAttackTotal": true,
    "ShowOverheat": true,
    "OverheatLogThreshold": 25,
    "ShowStability": true,

    "ArmorDamageColor": "WHITE",
    "SecondaryDamageColor": "ORANGE",
    "MeleeDamageColor": "CYAN",
    "RoundBreakColor": "#888888",
    "StructureDamageColor": "#FF8C00",
    "MechDestroyedColor": "#FF2222",
    "DestroyedLocationColor": "#FF4444",
    "PilotInjuryColor": "PINK",
    "CalledShotColor": "#B266FF",
    "HeatDamageColor": "#FFD700",
    "StabilityColor": "#66B2FF",
    "AttackTotalColor": "WHITE",
    "FriendlyNameColor": "#BCE8B0",

    "PanicColor": "YELLOW",
    "ThresholdColor": "ORANGE",
    "BleedColor": "RED",
    "IncapColor": "RED",
    "HealthColor": "WHITE",
    "SalvageColor": "GREEN",

    "WindowX": -1,
    "WindowY": 200,
    "WindowWidth": 320,
    "WindowHeight": 400,
    "FontSize": 10
  }
}
